{
  "openapi": "3.1.0",
  "info": {
    "version": "1.0.0",
    "title": "My Zuplo API"
  },
  "paths": {
    "/path-0": {
      "x-zuplo-path": {
        "pathMode": "open-api"
      },
      "get": {
        "summary": "Backend Echo Route",
        "description": "Forwards request to echo.zuplo.io/path-0",
        "operationId": "echoBackend",
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "baseUrl": "https://echo.zuplo.io"
            }
          },
          "policies": {
            "inbound": []
          }
        }
      }
    },
    "/get-request-header": {
      "x-zuplo-path": {
        "pathMode": "open-api"
      },
      "post": {
        "summary": "Get request header V2",
        "description": "Return the value of a specific request header by name. Requests for the 'sam' header must be blocked.",
        "operationId": "getRequestHeaderV2",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "header"
                ],
                "properties": {
                  "header": {
                    "type": "string",
                    "description": "The name of the header to retrieve"
                  }
                },
                "additionalProperties": false
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Header value returned",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "header": {
                      "type": "string"
                    },
                    "value": {
                      "type": [
                        "string",
                        "null"
                      ]
                    }
                  },
                  "required": [
                    "header",
                    "value"
                  ],
                  "additionalProperties": false
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "403": {
            "description": "Blocked request"
          },
          "500": {
            "description": "Internal error"
          },
          "502": {
            "description": "Upstream error"
          }
        },
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "export": "default",
            "module": "$import(./modules/get-header)",
            "options": {}
          },
          "policies": {
            "inbound": []
          },
          "mcp": {
            "type": "tool",
            "name": "get_request_header_v2",
            "description": "Return the value of a specific request header by name. Requests for the 'sam' header must be blocked."
          }
        }
      }
    },
    "/mcp": {
      "x-zuplo-path": {
        "pathMode": "open-api"
      },
      "post": {
        "summary": "MCP Server",
        "description": "Default MCP Server",
        "operationId": "mcpServer",
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "export": "mcpServerHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "name": "Header MCP Server",
              "version": "1.0.0",
              "operations": [
                {
                  "file": "./config/routes.oas.json",
                  "id": "getRequestHeaderV2"
                }
              ]
            }
          },
          "policies": {
            "inbound": []
          }
        }
      }
    }
  }
}